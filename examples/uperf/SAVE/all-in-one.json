{
    "benchmarks": [
        {
            "name": "uperf",
            "ids": "1-64",
            "mv-params": {
                "global-options": [
                    {
                        "name": "common-params",
                        "params": [
                            {
                                "arg": "duration",
                                "vals": [
                                    "10"
                                ]
                            },
                            {
                                "arg": "protocol",
                                "vals": [
                                    "tcp"
                                ]
                            },
                            {
                                "arg": "nthreads",
                                "vals": [
                                    "64"
                                ]
                            },
                            {
                                "arg": "ifname",
                                "vals": [
                                    "eth0"
                                ],
                                "role": "server"
                            }
                        ]
                    }
                ],
                "sets": [
                    {
                        "include": "common-params",
                        "params": [
                            {
                                "arg": "test-type",
                                "vals": [
                                    "stream"
                                ]
                            },
                            {
                                "arg": "wsize",
                                "vals": [
                                    "32768"
                                ]
                            }
                        ]
                    }
                ]
            }
        }
    ],
    "endpoints": [
        {
            "type": "kube",
            "host": "nvd-srv-44.my.com",
            "user": "root",
            "engines": {
                "client": "1",
                "server": "1"
            },
            "namespace": {
                "type": "custom",
                "name": "crucible-rickshaw"
            },
            "kubeconfig": "/root/sagi/openshift-dpf/kubeconfig",
            "sysinfo": {
                "collect-must-gather": false
            },
            "config": [
                {
                    "settings": {
                        "nodeSelector": {
                            "kubernetes.io/hostname": "nvd-srv-22.my.com"
                        }
                    },
                    "targets": [
                        {
                            "role": "client",
                            "ids": "1"
                        }
                    ]
                },
                {
                    "settings": {
                        "nodeSelector": {
                            "kubernetes.io/hostname": "nvd-srv-23.my.com"
                        }
                    },
                    "targets": [
                        {
                            "role": "server",
                            "ids": "1"
                        }
                    ]
                },
                {
                    "settings": {
                        "resources": {
                            "requests": {
                                "openshift.io/bf3-p0-vfs": 1,
                                "cpu": "117"
                            },
                            "limits": {
                                "openshift.io/bf3-p0-vfs": 1
                            }
                        },
                        "annotations": {
                            "v1.multus-cni.io/default-network": "ovn-kubernetes/dpf-ovn-kubernetes",
                            "irq-load-balancing.crio.io": "disable",
                            "cpu-quota.crio.io": "disable"
                        },
                        "userenv": "fedora-latest",
                        "osruntime": "pod"
                    },
                    "targets": "default"
                }
            ]
        }
    ],
    "run-params": {
        "num-samples": 1,
        "max-sample-failures": 1
    },
    "tags": {
        "mtu": "1400",
        "rcos": "9.6.20251110-1",
        "kernel": "5.14.0-570.64.1.el9_6.x86_64",
        "irq": "bal",
        "userenv": "fedora-latest",
        "topo": "internode",
        "pods-per-worker": "1",
        "scale_out_factor": "1",
        "nic": "BF3",
        "arch": "INTEL(R)_XEON(R)_GOLD_6548Y+",
        "model": "DPU",
        "cpu": "117"
    },
    "tool-params": [
        {
            "tool": "sysstat"
        },
        {
            "tool": "procstat"
        }
    ]
}
