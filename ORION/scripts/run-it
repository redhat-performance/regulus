#!/bin/bash
# Set ES_SERVER environment variable or update the default below
ES_SERVER="${ES_SERVER:-http://localhost:9200}"

# Use --rm to automatically remove container after it exits (prevents container buildup)
podman run --rm --user=root -v $(pwd):/orion:Z -w /orion orion --es-server="$ES_SERVER" "$@"

# example:  ./run-it --config examples/regulus-dataplane.yaml --hunter-analyze  --benchmark-index=regulus-results-* --metadata-index=regulus-results-* --lookback=15d
# podman pull quay.io/cloud-bulldozer/orion:latest
